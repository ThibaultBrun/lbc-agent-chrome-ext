{
  "manifest_version": 3,
  "name": "LBC Analyzer",
  "version": "0.1.0",
  "description": "Analyse une annonce Leboncoin avec le modèle IA embarqué dans Chrome (Gemini Nano).",
  "minimum_chrome_version": "127",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://www.leboncoin.fr/*"
  ],
  "action": {
    "default_title": "Analyser cette annonce Leboncoin",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.leboncoin.fr/ad/*", "https://www.leboncoin.fr/*/*.htm*"],
      "js": ["content/extract.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
